# Виртуальные окружения: в них уже стоит torch с сотнями МБ,
# в образ ставим чистый набор зависимостей отдельно
venv/
.venv/
env/

# Байткод и кэши инструментов — пересоздаются внутри контейнера
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Логи обучения, если их когда-нибудь начнут писать в файл
*.log

# Кэш Hugging Face datasets, если его случайно положили рядом с кодом
.cache/
.huggingface/

# VCS и артефакты сборки Docker — в рантайме не нужны
.git/
.gitignore
Dockerfile
.dockerignore

# Веса модели: поставляются через volume (compose), в образе не нужны.
# К тому же они в .gitignore — на чужом clone COPY здесь всё равно нечего копировать
weights/
